---
import type { ComponentProps, HTMLAttributes } from "astro/types";
import { Code } from "astro:components";
import { escapeString } from "../utils/escape-string";
import { transformerTwoslash, rendererRich } from "@shikijs/twoslash";
import path from "node:path";
import { JsxEmit } from "typescript";
import "@shikijs/twoslash/style-rich.css";

type Props = {
	files: { path: string; code: string }[];
	deps?: { path: string; code: string }[];
	config?: Omit<ComponentProps<typeof Code>, "code">;
	dataId?: string;
} & HTMLAttributes<"div">;

const {
	files,
	"class:list": classes,
	class: className,
	config,
	dataId: dataIdProp,
	deps = [],
	...props
} = Astro.props;

const dataId = dataIdProp ? escapeString(dataIdProp) : "activeFile";

const file = files[0];
if (file === undefined) throw new Error("Must contain one file");
const defaultPath = escapeString(file.path);

type StringRecord = Record<string, string>;

const allFiles = [...files, ...deps];
---

<div
  class:list={["not-prose bg-stone-100 rounded-2xl overflow-hidden relative", className, classes]}
  {...(dataIdProp ? {} : {"x-data": `{ '${dataId}': '${defaultPath}' }`})}
  {...props}
>
  <div class="border-stone-200 px-2 flex overflow-x-auto pt-2 absolute bg-gradient-to-b from-stone-100 from-40% to-transparent w-full pb-6">
    {files.map((file) => {
      const filePath = escapeString(file.path)
      const path = file.path.split("/")
      return (
        <button
          @click=`${dataId} = '${filePath}'`
          :data-active=`${dataId} === '${filePath}'`
          class="shrink-0 border border-transparent data-active:bg-stone-200 data-active:border-stone-300 data-active:text-stone-800 text-stone-500 rounded-full px-3 py-0.5 text-sm cursor-pointer"
        >
          {path.map((entry, index) => {
            const isLast = index === path.length - 1
            return <span class:list={[!isLast && "opacity-75"]}>
              {entry}
              {!isLast && "/"}
            </span>
          })}
        </button>
      )
    })}
  </div>
  {files.map((file) => {
    const otherFiles = allFiles.filter(f => f.path !== file.path).reduce((acc, curr) => {
      const relativePath = path.relative(file.path, curr.path).slice(1)
      acc[relativePath]= curr.code;
      return acc
    }, {} as StringRecord);

    return <Code code={file.code} {...config}
      transformers={[
        transformerTwoslash({ renderer: rendererRich(), twoslashOptions: {
          extraFiles: otherFiles,
          compilerOptions: {
            jsx: JsxEmit.ReactJSX,
            jsxImportSource: 'react'
          }
        }})
      ]}
      class="max-h-180 p-3 pt-12 text-sm leading-6" x-show=`${dataId} === '${escapeString(file.path)}'` />
    })
  }
</div>
